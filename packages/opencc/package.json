{
  "name": "@kurajs/opencc",
  "version": "0.0.1",
  "type": "module",
  "description": "Kura — opt-in Traditional/Simplified Chinese normalization (OpenCC) for @kurajs/search, to match keyword queries across 繁/簡 variants.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "keywords": [
    "kura",
    "opencc",
    "chinese",
    "traditional",
    "simplified",
    "zh-tw",
    "normalization"
  ],
  "homepage": "https://kura.build",
  "license": "MIT",
  "dependencies": {
    "@kurajs/search": "^0.0.1",
    "opencc-js": "^1.0.5"
  },
  "devDependencies": {
    "@kurajs/tokenizers": "^0.0.1",
    "typescript": "^5.7.0"
  },
  "author": "Lawrence Lin",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kurajs/kura.git",
    "directory": "packages/opencc"
  }
}
