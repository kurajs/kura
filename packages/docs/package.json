{
  "name": "@kurajs/docs",
  "version": "0.0.8",
  "type": "module",
  "description": "Kura — the docs framework on June. Sidebar, ToC, search, copy-markdown, and the agent surface (MCP) for a knowledgebase that serves humans and agents.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js"
    },
    "./mdx": {
      "types": "./dist/mdx.d.ts",
      "import": "./dist/mdx.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./meta": {
      "types": "./dist/meta.d.ts",
      "import": "./dist/meta.js"
    },
    "./css": "./css/preset.css"
  },
  "files": [
    "dist",
    "css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "keywords": [
    "kura",
    "june",
    "docs",
    "documentation",
    "sidebar",
    "toc",
    "mcp",
    "agent-native"
  ],
  "homepage": "https://kura.build",
  "license": "MIT",
  "dependencies": {
    "@kurajs/core": "^0.0.1",
    "@mdx-js/mdx": "^3.1.0",
    "remark-gfm": "^4.0.0"
  },
  "peerDependencies": {
    "@junejs/core": ">=0.0.29 <0.1.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "@junejs/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@junejs/core": "^0.0.27",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.7.0"
  },
  "author": "Lawrence Lin",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kurajs/kura.git",
    "directory": "packages/docs"
  }
}
